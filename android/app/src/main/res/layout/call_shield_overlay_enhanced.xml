<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Semi-transparent overlay background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <!-- Main glassmorphic card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/overlay_card_view"
        style="@style/Widget.SignalGate.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_gravity="center_horizontal|center_vertical"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Incoming Call Label -->
            <TextView
                android:id="@+id/incoming_call_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incoming call"
                style="@style/TextAppearance.SignalGate.Muted"
                android:layout_gravity="center_horizontal" />

            <!-- Caller Number -->
            <TextView
                android:id="@+id/caller_number_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+1 (800) 555-0199"
                style="@style/TextAppearance.SignalGate.Header"
                android:textSize="32sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <!-- Caller Country -->
            <TextView
                android:id="@+id/caller_country_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="United States"
                style="@style/TextAppearance.SignalGate.Subtitle"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp" />

            <!-- Shield and Spam Info Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- Shield Icon -->
                <ImageView
                    android:id="@+id/shield_icon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="SignalGate Shield"
                    android:scaleType="centerInside" />

                <!-- Spam Status and Confidence -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/spam_status_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIKELY SPAM"
                        style="@style/TextAppearance.SignalGate.Header"
                        android:textColor="@color/status_medium"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/spam_category_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Telemarketing"
                        style="@style/TextAppearance.SignalGate.Subtitle"
                        android:layout_marginTop="2dp" />

                    <!-- Confidence Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/confidence_text_view"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Confidence: 92%"
                            style="@style/TextAppearance.SignalGate.Body"
                            android:textSize="12sp" />

                        <ProgressBar
                            android:id="@+id/confidence_progress_bar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="4dp"
                            android:layout_weight="1"
                            android:progress="92"
                            android:progressTint="@color/status_medium"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Risk Level Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/status_high"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    android:layout_marginStart="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RISK LEVEL"
                            style="@style/TextAppearance.SignalGate.Muted"
                            android:textSize="9sp"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/risk_level_text_view"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HIGH"
                            style="@style/TextAppearance.SignalGate.Header"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />

                        <!-- Heartbeat Graphic Placeholder -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="12dp"
                            android:src="@android:drawable/ic_media_play"
                            android:tint="@color/text_primary"
                            android:contentDescription="Risk Level Graphic"
                            android:layout_marginTop="4dp"
                            android:scaleType="fitCenter" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Matched Sources Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|space_between">

                    <TextView
                        android:id="@+id/matched_sources_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Matched in 3 sources"
                        style="@style/TextAppearance.SignalGate.Body"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/matched_sources_timestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Just now"
                        style="@style/TextAppearance.SignalGate.Muted"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Source Tags Container (Horizontal Scrollable) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:id="@+id/source_tags_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Source Tags will be added programmatically -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Community Feed"
                            style="@style/TextAppearance.SignalGate.Muted"
                            android:background="@drawable/tag_background"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Telemarketer DB"
                            style="@style/TextAppearance.SignalGate.Muted"
                            android:background="@drawable/tag_background"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Reports"
                            style="@style/TextAppearance.SignalGate.Muted"
                            android:background="@drawable/tag_background"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:spacing="8dp">

                <Button
                    android:id="@+id/allow_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="ALLOW"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:backgroundTint="@color/status_low"
                    android:drawableStart="@android:drawable/sym_action_call"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/screen_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="SCREEN"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:backgroundTint="@color/background_secondary"
                    android:drawableStart="@android:drawable/ic_menu_view"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/block_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="BLOCK"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:backgroundTint="@color/status_high"
                    android:drawableStart="@android:drawable/sym_action_call"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>

            <!-- More Details Button -->
            <Button
                android:id="@+id/more_details_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="More Details"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/text_secondary"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
