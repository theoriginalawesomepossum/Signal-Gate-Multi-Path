<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_md"
    android:paddingTop="@dimen/space_md"
    android:paddingEnd="@dimen/space_md"
    android:paddingBottom="@dimen/space_md"
    android:background="@color/background_primary">

    <!-- SCREEN TITLE -->
    <TextView
        android:id="@+id/blockedNumbersTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Blocked Numbers"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.SignalGate.Headline"
        android:layout_marginBottom="@dimen/space_lg" />

    <!-- ACTION BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/addBlockedNumberButton"
        style="@style/SignalGateButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Add Blocked Number"
        android:layout_marginBottom="@dimen/space_lg" />

    <!-- CONTENT CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:strokeColor="@color/surface_border"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- BLOCKED NUMBERS LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewBlockedNumbers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="@dimen/space_sm"
                android:paddingBottom="@dimen/space_sm" />

            <!-- EMPTY STATE -->
            <TextView
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="@dimen/space_lg"
                android:text="No blocked numbers yet.\nTap the button above to add one."
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.SignalGate.Body"
                android:textColor="@color/text_muted"
                android:visibility="gone" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
