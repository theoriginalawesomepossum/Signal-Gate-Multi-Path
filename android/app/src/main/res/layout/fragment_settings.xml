<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- HEADER: Logo left + Status + Multi-Point Hub button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <!-- Logo - Top Left (larger) -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_signal_gate_logo"
            android:contentDescription="Signal Gate Logo"
            android:layout_marginEnd="16dp" />

        <!-- Status and Button column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Status text - top aligned with logo -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SignalGate Status: Active"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#00C853" />

            <!-- Multi-Point Hub button - bottom aligned with logo -->
            <Button
                android:id="@+id/multiPointHubButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MULTI-POINT HUB"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Horizontal separator under header -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="24dp" />

    <!-- Page title / breadcrumb -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings / Colors"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Shield Preview -->
    <View
        android:id="@+id/previewShield"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#4285F4"/>

    <!-- Color Picker -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Red:"
        android:textSize="16sp"
        android:layout_marginBottom="4dp"/>

    <SeekBar
        android:id="@+id/redSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="255"
        android:progress="66"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Green:"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"/>

    <SeekBar
        android:id="@+id/greenSeekBar
