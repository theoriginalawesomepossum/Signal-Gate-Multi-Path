<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/space_lg"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Settings"
            android:gravity="center"
            android:layout_marginBottom="@dimen/space_xl"
            android:textAppearance="@style/TextAppearance.SignalGate.Headline" />

        <!-- CRASH LOGS BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewCrashLogsButton"
            style="@style/SignalGateButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="View Crash Logs" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
