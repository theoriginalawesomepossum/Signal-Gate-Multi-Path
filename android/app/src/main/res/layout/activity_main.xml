<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- ========================================================= -->
    <!-- PROFESSIONAL HEADER CARD -->
    <!-- ========================================================= -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_marginEnd="@dimen/space_lg"
        android:padding="@dimen/header_padding"
        android:background="@drawable/bg_header_card">

        <!-- App Title -->
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/space_md"
            android:text="SignalGate"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/statusText" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/appSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Smart Call Protection"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_small"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/appTitle"
            app:layout_constraintEnd_toStartOf="@id/statusText"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Active"
            android:textColor="@color/success"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ========================================================= -->
    <!-- ACTION BUTTON ROW -->
    <!-- ========================================================= -->

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/actionButtonContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/space_lg"
            android:paddingBottom="@dimen/space_md">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/multiPointHubButton"
                style="@style/SignalGateButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:layout_marginEnd="@dimen/space_md"
                android:text="MULTI-POINT HUB" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/helpButton"
                style="@style/SignalGateButton"
                android:layout_width="@dimen/button_height"
                android:layout_height="@dimen/button_height"
                android:text="?"
                android:textSize="@dimen/text_subtitle" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ========================================================= -->
    <!-- DIVIDER -->
    <!-- ========================================================= -->

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginEnd="@dimen/space_lg"
        android:background="@color/divider_color" />

    <!-- ========================================================= -->
    <!-- SETUP / PERMISSIONS CARD -->
    <!-- ========================================================= -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/setupCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_lg"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/setupContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/setDefaultButton"
                style="@style/SignalGateButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/space_md"
                android:text="Set as Default Call Screener"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/requestContactsButton"
                style="@style/SignalGateButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/space_md"
                android:text="Grant Contacts Permission"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/manageBlockedNumbersButton"
                style="@style/SignalGateButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Manage Blocked Numbers"
                android:visibility="gone" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ========================================================= -->
    <!-- MAIN CONTENT -->
    <!-- ========================================================= -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/space_xs"
        tools:layout="@layout/fragment_recent_calls" />

    <!-- ========================================================= -->
    <!-- FOOTER LOGO -->
    <!-- ========================================================= -->

    <ImageView
        android:id="@+id/footerLogo"
        android:layout_width="@dimen/logo_footer_size"
        android:layout_height="@dimen/logo_footer_size"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginBottom="@dimen/space_md"
        android:src="@drawable/ic_signal_gate_logo"
        android:contentDescription="SignalGate Logo"
        android:alpha="0.92" />

    <!-- ========================================================= -->
    <!-- BOTTOM NAVIGATION -->
    <!-- ========================================================= -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@color/bottom_nav_background"
        app:itemIconTint="@android:color/white"
        app:itemRippleColor="@color/ripple_color"
        app:itemTextColor="@android:color/white"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
