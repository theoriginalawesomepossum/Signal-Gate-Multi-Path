<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_md"
    android:paddingTop="@dimen/space_md"
    android:paddingEnd="@dimen/space_md"
    android:paddingBottom="@dimen/space_md"
    android:background="@color/background_primary"
    tools:context=".ui.RecentCallsFragment">

    <!-- SCREEN TITLE -->
    <TextView
        android:id="@+id/recentCallsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recent Calls"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.SignalGate.Headline"
        android:layout_marginBottom="@dimen/space_lg" />

    <!-- CONTENT CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:strokeColor="@color/surface_border"
        app:strokeWidth="1dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- RECENT CALLS LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="@dimen/space_sm"
                android:paddingBottom="@dimen/space_sm"
                tools:listitem="@layout/item_recent_call" />

            <!-- EMPTY STATE -->
            <TextView
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="No recent calls"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.SignalGate.Body"
                android:textColor="@color/text_muted"
                android:visibility="gone" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
