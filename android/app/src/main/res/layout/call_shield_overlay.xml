<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <!-- Main Overlay Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <!-- Glassmorphic Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Shield Icon and Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/shield_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_shield"
                        android:contentDescription="Shield Icon"
                        android:tint="#4285F4" />

                    <TextView
                        android:id="@+id/spam_status_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIKELY SPAM"
                        android:textColor="#FF9800"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp" />

                </LinearLayout>

                <!-- Caller Number -->
                <TextView
                    android:id="@+id/caller_number_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+1 (800) 555-0199"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <!-- Caller Location -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="United States"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- Spam Category -->
                <TextView
                    android:id="@+id/spam_category_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Telemarketing"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <!-- Confidence Progress Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Confidence"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/confidence_text_view"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92%"
                            android:textColor="#FF9800"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/confidence_progress_bar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:progress="92"
                        android:progressDrawable="@drawable/progress_bar_drawable"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>

                <!-- Risk Level -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Risk Level"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/risk_level_text_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HIGH"
                        android:textColor="#F44336"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/risk_level_badge"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" />

                </LinearLayout>

                <!-- Matched Sources -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/matched_sources_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Matched in 3 sources"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/source_tags_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>

                <!-- More Details Section (Expandable) -->
                <LinearLayout
                    android:id="@+id/details_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Call History"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Just now • Blocked"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                </LinearLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <!-- Allow Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/allow_button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="ALLOW"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#4CAF50"
                        app:cornerRadius="12dp" />

                    <!-- Screen Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/screen_button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_marginStart="8dp"
                        android:text="SCREEN"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#2196F3"
                        app:cornerRadius="12dp" />

                    <!-- Block Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/block_button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="BLOCK"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#F44336"
                        app:cornerRadius="12dp" />

                </LinearLayout>

                <!-- More Details Toggle Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/more_details_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="More Details"
                    android:textColor="#4285F4"
                    android:textSize="12sp"
                    app:strokeColor="#4285F4"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Call Control Buttons (Bottom) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <!-- Accept Call -->
            <ImageButton
                android:id="@+id/accept_call_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_call_accept"
                android:contentDescription="Accept Call"
                android:background="@drawable/circular_button_green"
                android:scaleType="centerInside" />

            <!-- Reject Call -->
            <ImageButton
                android:id="@+id/reject_call_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_call_reject"
                android:contentDescription="Reject Call"
                android:background="@drawable/circular_button_red"
                android:scaleType="centerInside" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
