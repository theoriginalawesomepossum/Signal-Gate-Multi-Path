<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/space_lg"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Incoming Call Blocked"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.SignalGate.SectionTitle"
            android:layout_marginBottom="@dimen/space_sm" />

        <!-- PHONE NUMBER -->
        <TextView
            android:id="@+id/phoneNumberText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.SignalGate.Headline"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- DESCRIPTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="What would you like to do?"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.SignalGate.Body"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/blockThisTimeButton"
                style="@style/SignalGateButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Block This Time"
                android:layout_marginBottom="@dimen/space_sm"
                android:backgroundTint="@color/warning" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/blockPermanentlyButton"
                style="@style/SignalGateButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Block Permanently"
                android:layout_marginBottom="@dimen/space_sm"
                android:backgroundTint="@color/error" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dismissButton"
                style="@style/SignalGateButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Dismiss" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
