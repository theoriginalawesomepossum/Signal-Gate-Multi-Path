<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/background_primary</item>
        <item name="colorPrimaryDark">@color/background_primary</item>
        <item name="colorAccent">@color/accent_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Glassmorphism Card Style -->
    <style name="Widget.SignalGate.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/overlay_glass</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#33FFFFFF</item> <!-- Semi-transparent white for border -->
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.SignalGate.Header" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SignalGate.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SignalGate.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SignalGate.Muted" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_muted</item>
    </style>

</resources>
